# Copy to .env.docker before running Docker Compose.

# Database: service host is the Compose service name "db".
DATABASE_URL=postgresql+asyncpg://maple_app:maple_app_password@db:5432/maple_a1

# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=change-me-docker-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# GitHub token encryption
# Replace this local-development Fernet key before using real credentials.
# Generate a new key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GITHUB_TOKEN_ENCRYPTION_KEY=dGhpc19pc19hXzMyX2J5dGVfZGV2X3Rlc3Rfa2V5ISE=

# Docker sandbox access: keep sibling containers on the host daemon.
DOCKER_SOCKET_URL=unix:///var/run/docker.sock
DOCKER_CONTAINER_TIMEOUT=60

# Browser origin for the bundled Nginx frontend.
CORS_ORIGINS=http://localhost

# Optional LLM providers
GEMINI_API_KEY=
OPENAI_API_KEY=
