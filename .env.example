# -- Database (DigitalOcean Managed PostgreSQL) --
DATABASE_URL=postgresql+asyncpg://user:password@host:25060/maple_a1?sslmode=require
DATABASE_HOST=localhost
DATABASE_PORT=25060
DATABASE_USER=maple_app
DATABASE_PASSWORD=changeme
DATABASE_NAME=maple_a1

# -- Application --
APP_ENV=development          # development | production
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=changeme          # used for signing JWT tokens

# -- Auth --
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# -- GitHub (ingestion pipeline + test-suite cloning) --
# Minimum required scopes:
#   - repo            (full read access to private student and instructor repos)
# If the PAT only has public_repo scope, cloning private instructor test-suite
# repos will fail (the pipeline treats this as a safe, logged clone error — the
# submission moves to "Failed" without leaking credentials).
#
# Recommended owner: a service account or the instructor's account with access
# to both student submission repos and private test-suite repos.
GITHUB_PAT=ghp_xxxxxxxxxxxx

# -- LLM API Keys (Milestone 3, but placeholder now) --
GEMINI_API_KEY=changeme
OPENAI_API_KEY=changeme

# -- CORS --
# Local: Angular dev server. Production: comma-separated HTTPS origins of the *browser* page (SPA), e.g.
#   CORS_ORIGINS=https://app.maple-a1.com
# Do not list the API hostname here unless the SPA is served from the same origin as the API.
CORS_ORIGINS=http://localhost:4200
